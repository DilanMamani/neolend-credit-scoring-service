        {
          "name": "GET /api/support/applications/:applicationId (detalle)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/support/applications/{{applicationId}}", "host": ["{{baseUrl}}"], "path": ["api", "support", "applications", "{{applicationId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
