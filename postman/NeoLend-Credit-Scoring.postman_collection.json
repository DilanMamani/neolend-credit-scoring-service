              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('decision APPROVED y tipo MANUAL', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.decision).to.eql('APPROVED');",
                  "  pm.expect(body.data.decisionType).to.eql('MANUAL');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/approval/decision/:applicationId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/approval/decision/{{manualReviewApplicationId}}", "host": ["{{baseUrl}}"], "path": ["api", "approval", "decision", "{{manualReviewApplicationId}}"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] } }
          ]
        },
        {
          "name": "PATCH /api/approval/:applicationId/analyst-decision (REJECTED)",
          "request": {
            "method": "PATCH",
