{
  "info": {
    "name": "NeoLend Credit Scoring Service",
    "description": "Colección completa para probar el microservicio neolend-credit-scoring-service (scoring + aprobación automática/manual + auditoría regulatoria). Sin autenticación: no requiere tokens.\n\nFlujo recomendado: corre las carpetas en orden (1 → 5). La carpeta 3 'Flujo Autocontenido' genera su propio applicationId (UUID aleatorio) y no depende de que otro microservicio haya creado la solicitud previamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a1e6c1c0-7f3e-4f6e-9a2a-neolend-scoring-001"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001", "type": "string" },
    { "key": "applicationId", "value": "55c9a553-b85e-4059-8cf1-9c666fd2bd9e", "type": "string", "description": "Seed: 'Compra de celular para trabajo', USD 300" },
    { "key": "applicantId", "value": "655c0e87-f255-44cf-9f6d-74f03ccd3f28", "type": "string", "description": "Solicitante asociado a applicationId (document SC-9988776)" },
    { "key": "manualReviewApplicationId", "value": "b5a06064-b06c-42f5-ab4b-1259f5419603", "type": "string", "description": "Seed: 'Capital de trabajo para emprendimiento', USD 1200 (> límite automático)" },
    { "key": "manualReviewApplicantId", "value": "1b34bfa8-8300-486b-8970-71561763dfea", "type": "string", "description": "Solicitante asociado a manualReviewApplicationId (document CB-7654321)" },
    { "key": "analystId", "value": "79eaa2d0-4cb9-455e-bb52-39a47c624884", "type": "string", "description": "Usuario con rol ANALISTA (María López)" },
    { "key": "freshApplicantId", "value": "a6491c65-fda9-4c58-b6c8-1f62edf336b0", "type": "string", "description": "Solicitante sembrado SIN solicitud de crédito todavía (document 12345678): ideal para el flujo autocontenido" },
    { "key": "freshApplicationId", "value": "", "type": "string", "description": "Se genera automáticamente (UUID) en la carpeta 'Flujo Autocontenido'" },
    { "key": "targetModel", "value": "model-v2-blue", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('service ok', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.service).to.eql('neolend-credit-scoring-service');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Scoring (datos sembrados)",
      "item": [
        {
          "name": "POST /api/scoring/evaluate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicationId\": \"{{applicationId}}\",\n  \"applicantId\": \"{{applicantId}}\",\n  \"requestedAmount\": 300\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/scoring/evaluate", "host": ["{{baseUrl}}"], "path": ["api", "scoring", "evaluate"] },
            "description": "Corre el pipeline completo de scoring sobre una solicitud ya sembrada en la base. Si ya existe snapshot de datos externos, lo reutiliza; siempre crea un nuevo registro en scoring.scoring_results."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('success true', () => pm.expect(body.success).to.be.true);",
                  "pm.test('score en rango 300-850', () => {",
                  "  pm.expect(body.data.score).to.be.at.least(300);",
                  "  pm.expect(body.data.score).to.be.at.most(850);",
                  "});",
                  "pm.test('riskLevel valido', () => pm.expect(['LOW','MEDIUM','HIGH']).to.include(body.data.riskLevel));",
                  "pm.collectionVariables.set('lastScore', body.data.score);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/scoring/result/:applicationId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/scoring/result/{{applicationId}}", "host": ["{{baseUrl}}"], "path": ["api", "scoring", "result", "{{applicationId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('trae score guardado', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('score');",
                  "  pm.expect(body.data).to.have.property('shapValues');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/scoring/explanation/:applicationId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/scoring/explanation/{{applicationId}}", "host": ["{{baseUrl}}"], "path": ["api", "scoring", "explanation", "{{applicationId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('explanation es un arreglo no vacio', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.explanation).to.be.an('array').that.is.not.empty;",
                  "  pm.expect(body.data.explanation[0]).to.have.property('factor');",
                  "  pm.expect(body.data.explanation[0]).to.have.property('description');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/scoring/result/:applicationId (404 - no existe)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/scoring/result/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api", "scoring", "result", "00000000-0000-0000-0000-000000000000"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', () => pm.response.to.have.status(404));",
                  "pm.test('success false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Flujo Autocontenido (sin datos previos)",
      "description": "Genera un applicationId nuevo (UUID aleatorio) y lo combina con un applicant ya sembrado pero SIN solicitud de crédito creada (freshApplicantId). Demuestra que scoring-service y approval-service funcionan sin depender de credit-application-service.",
      "item": [
        {
          "name": "POST /api/scoring/evaluate (autocontenido)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('freshApplicationId')) {",
                  "  pm.collectionVariables.set('freshApplicationId', pm.variables.replaceIn('{{$guid}}'));",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('success true', () => pm.expect(body.success).to.be.true);",
                  "pm.collectionVariables.set('freshScore', body.data.score);",
                  "console.log('freshApplicationId usado:', pm.collectionVariables.get('freshApplicationId'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicationId\": \"{{freshApplicationId}}\",\n  \"applicantId\": \"{{freshApplicantId}}\",\n  \"requestedAmount\": 480\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/scoring/evaluate", "host": ["{{baseUrl}}"], "path": ["api", "scoring", "evaluate"] },
            "description": "No existe snapshot externo para este applicationId: el servicio consulta (vía circuit breaker) el buró simulado y genera el resto de fuentes alternativas él mismo."
          }
        },
        {
          "name": "POST /api/approval/automatic (autocontenido)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicationId\": \"{{freshApplicationId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/approval/automatic", "host": ["{{baseUrl}}"], "path": ["api", "approval", "automatic"] },
            "description": "No existe fila en credit.credit_applications para este applicationId: el monto y el applicantId se resuelven leyendo el evento ScoringStarted registrado por la solicitud anterior."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('decision valida', () => pm.expect(['APPROVED','REJECTED','MANUAL_REVIEW']).to.include(body.data.decision));",
                  "pm.test('no quedo en MANUAL_REVIEW por datos incompletos', () => {",
                  "  pm.expect(body.data.reason).to.not.include('Datos incompletos');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/approval/decision/:freshApplicationId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/approval/decision/{{freshApplicationId}}", "host": ["{{baseUrl}}"], "path": ["api", "approval", "decision", "{{freshApplicationId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "GET /api/support/audit/:freshApplicationId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/support/audit/{{freshApplicationId}}", "host": ["{{baseUrl}}"], "path": ["api", "support", "audit", "{{freshApplicationId}}"] },
            "description": "Muestra la cadena de eventos firmados (ScoringStarted -> ScoringCompleted -> AutomaticApprovalCompleted) y la auditoría de decisión."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('hay al menos 3 eventos encadenados', () => {",
                  "  pm.expect(body.data.events.length).to.be.at.least(3);",
                  "});",
                  "pm.test('cadena de hashes valida', () => {",
                  "  const events = body.data.events;",
                  "  for (let i = 1; i < events.length; i++) {",
                  "    pm.expect(events[i].previous_hash).to.eql(events[i-1].hash);",
                  "  }",
                  "});",
                  "pm.test('decisionAudit tiene firma digital', () => {",
                  "  pm.expect(body.data.decisionAudit[0].digital_signature).to.be.a('string').with.length.above(10);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
