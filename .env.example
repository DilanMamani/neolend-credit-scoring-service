# ==========================================
# SERVER
# ==========================================
PORT=3001
NODE_ENV=development

# ==========================================
# DATABASE - NEON
# ==========================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# ==========================================
# APP
# ==========================================
APP_NAME=NeoLend Financial Corp
APP_VERSION=1.0.0

# ==========================================
# SCORING / APROBACION
# ==========================================
AUTO_APPROVAL_LIMIT=500
MIN_SCORE_APPROVAL=700
MIN_SCORE_MANUAL_REVIEW=600

# ==========================================
# CIRCUIT BREAKER - BURO DE CREDITO (SOAP/mainframe simulado)
# ==========================================
CREDIT_BUREAU_TIMEOUT_MS=15000
CREDIT_BUREAU_FAILURE_THRESHOLD=5
CREDIT_BUREAU_RESET_TIMEOUT_MS=30000
CREDIT_BUREAU_RATE_LIMIT=10
CREDIT_BUREAU_FORCE_SLOW=false
CREDIT_BUREAU_FAILURE_RATE=0.12

# ==========================================
# BLUE/GREEN MODEL
# ==========================================
ACTIVE_MODEL=model-v2-green
STANDBY_MODEL=model-v2-blue

# ==========================================
# AUDITORIA / EVENT SOURCING
# ==========================================
AUDIT_ENABLED=true
EVENT_SOURCING_ENABLED=true
DIGITAL_SIGNATURE_SECRET=change-me-in-each-environment

# ==========================================
# CORS (vacío = permite cualquier origen)
# ==========================================
CORS_ORIGIN=
